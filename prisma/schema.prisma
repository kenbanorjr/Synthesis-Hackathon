generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StrategyStatus {
  ACTIVE
  PAUSED
  WATCHLIST
  AT_RISK
}

enum TriggerType {
  YIELD_DROP
  RISK_INCREASE
  BETTER_OPPORTUNITY
  MANUAL_REVIEW
}

enum RunStatus {
  RUNNING
  COMPLETED
  AWAITING_APPROVAL
  BLOCKED
  FAILED
}

enum AgentType {
  MONITOR
  RESEARCH
  RISK
  EXECUTION
  EXPLAINER
}

enum StepStatus {
  SUCCESS
  FAILED
  SKIPPED
  PENDING
}

enum ReceiptStatus {
  COMPLETED
  PENDING_APPROVAL
  REJECTED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActionType {
  BUY_ANALYTICS
  REBALANCE
  SWITCH_STRATEGY
  HEDGE_POSITION
}

enum IntegrationMode {
  MOCK
  REAL
}

enum DecisionOutcome {
  RECOMMENDED
  AWAITING_APPROVAL
  EXECUTED
  BLOCKED
  NO_ACTION
  REJECTED
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String?              @unique
  walletAddress       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  treasuryPolicy      TreasuryPolicy?
  strategies          MonitoredStrategy[]
  agentRuns           AgentRun[]
  integrationSettings IntegrationSettings?
}

model TreasuryPolicy {
  id                        String       @id @default(cuid())
  userId                    String       @unique
  monthlyBudgetUsd          Decimal      @db.Decimal(12, 2)
  maxSpendPerActionUsd      Decimal      @db.Decimal(12, 2)
  approvalThresholdUsd      Decimal      @db.Decimal(12, 2)
  allowedProviders          String[]
  allowedActions            ActionType[]
  autoExecuteLowRisk        Boolean      @default(false)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  user                      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MonitoredStrategy {
  id            String         @id @default(cuid())
  userId        String
  name          String
  protocol      String
  network       String
  assetSymbol   String
  currentYield  Decimal        @db.Decimal(8, 2)
  targetYield   Decimal        @db.Decimal(8, 2)
  riskScore     Decimal        @db.Decimal(5, 2)
  status        StrategyStatus @default(ACTIVE)
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentRuns     AgentRun[]

  @@unique([userId, name])
}

model AgentRun {
  id               String           @id @default(cuid())
  userId           String
  strategyId       String
  triggerType      TriggerType
  triggerSummary   String
  status           RunStatus
  requiresApproval Boolean          @default(false)
  finalDecision    DecisionOutcome
  confidenceScore  Decimal?         @db.Decimal(5, 2)
  createdAt        DateTime         @default(now())
  completedAt      DateTime?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy         MonitoredStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  steps            AgentStep[]
  receipts         PaymentReceipt[]
  recommendation   Recommendation?
  approvalRequest  ApprovalRequest?
}

model AgentStep {
  id         String     @id @default(cuid())
  agentRunId String
  agentType  AgentType
  title      String
  input      Json?
  output     Json?
  status     StepStatus
  createdAt  DateTime   @default(now())
  agentRun   AgentRun   @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
}

model PaymentReceipt {
  id           String        @id @default(cuid())
  agentRunId   String
  provider     String
  purpose      String
  amountUsd    Decimal       @db.Decimal(12, 2)
  currency     String        @default("USD")
  status       ReceiptStatus
  externalTxId String?
  reason       String
  metadata     Json?
  createdAt    DateTime      @default(now())
  agentRun     AgentRun      @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id             String   @id @default(cuid())
  agentRunId     String   @unique
  headline       String
  rationale      String
  proposedAction String
  expectedImpact String
  riskAssessment String
  createdAt      DateTime @default(now())
  agentRun       AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id         String         @id @default(cuid())
  agentRunId String         @unique
  title      String
  reason     String
  status     ApprovalStatus @default(PENDING)
  requestedAt DateTime      @default(now())
  resolvedAt DateTime?
  agentRun   AgentRun       @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
}

model IntegrationSettings {
  id               String          @id @default(cuid())
  userId           String          @unique
  openservMode     IntegrationMode @default(MOCK)
  locusMode        IntegrationMode @default(MOCK)
  demoMode         Boolean         @default(true)
  managedWalletRef String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}
